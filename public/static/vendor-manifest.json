  "holds": {
    "jquery": "jQuery 4 is outside Bootstrap 4.6.2's supported peer range, so the public theme remains on jQuery 3.7.1.",
    "publicBootstrap": "The compiled public theme and inherited views use Bootstrap 4 data APIs and utility classes, so the safest stable line is Bootstrap 4.6.2 until a full theme migration is owned.",
    "publicPopper": "Bootstrap 4.6.2 requires the discontinued Popper 1 package line. popper.js 1.16.1 is pinned for audit coverage, while the production bootstrap.bundle asset embeds the compatible runtime.",
    "dashboardBundle": "AdminKit 3.4.0 is the newest stable shell, but it still embeds Bootstrap 5.3.0 and Chart.js 2.9.4 and installs deprecated Babel polyfill and Core-JS 2 transitives. Shared chart configuration detects that bundled major, while stats pages replace the global once with standalone Chart.js 4.5.1 after the shell loads.",
    "fontawesomeIconpicker": "Font Awesome Icon Picker 3.2.0 is discontinued. It remains pinned at its final stable release because active theme-admin call sites depend on its jQuery API.",
    "fontselectPackageLayout": "fontselect-jquery-plugin 1.1.0 is pinned for inventory and audit coverage, but its non-searchable anchor-based UI is incompatible with the active searchable span-based font selector and existing CSS. The shipped compatible asset remains held until its UI can be migrated and tested."
  },
