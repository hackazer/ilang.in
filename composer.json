{
    "name": "gempixel/framework",
    "type": "project",
    "description": "GemPixel Framework",
    "license": "proprietary",
    "require": {
        "abraham/twitteroauth": "^8.2",
        "defuse/php-encryption": "^2.2",
        "endroid/qr-code": "^6.0",
        "jaybizzle/crawler-detect": "^1.2",
        "maxmind-db/reader": "^1.10",
        "monolog/monolog": "^3.10",
        "nikic/fast-route": "^1.3",
        "php": "^8.3",
        "phpfastcache/phpfastcache": "^9.2",
        "phpmailer/phpmailer": "^7.1",
        "setasign/fpdf": "^1.8",
        "stripe/stripe-php": "^21.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5"
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint": "sh scripts/lint-php.sh",
        "test": "@php vendor/bin/phpunit --configuration phpunit.xml"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    }
}
