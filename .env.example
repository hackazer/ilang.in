# ilang.in environment reference
#
# This application does not load .env automatically.
# Keep deployment secrets in the server environment and configure NOWPayments
# credentials through Admin > Settings > Payment Gateway > NOWPayments.
# Those NOWPayments credentials are encrypted in the database, not read here.

# Comma-separated proxy CIDRs trusted to provide forwarding headers.
# TRUSTED_PROXY_CIDRS=

# Set to 1 only when the application is behind a trusted Cloudflare edge.
# TRUST_CLOUDFLARE=

# NOWPAYMENTS_API_KEY=
# NOWPAYMENTS_IPN_SECRET=
# NOWPAYMENTS_DASHBOARD_EMAIL=
# NOWPAYMENTS_DASHBOARD_PASSWORD=
# NOWPAYMENTS_ENVIRONMENT=
# NOWPAYMENTS_SETTLEMENT_CURRENCY=
# NOWPAYMENTS_DEFAULT_PAY_CURRENCY=
# NOWPAYMENTS_DEFAULT_MODE=
# NOWPAYMENTS_ENABLED_MODES=
# NOWPAYMENTS_CUSTODIAL_ENABLED=
# NOWPAYMENTS_RECONCILIATION_ENABLED=
# NOWPAYMENTS_RECONCILIATION_INTERVAL_MINUTES=
